---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import PricingCard from "@/components/pricing.astro";

const pricing = [
  {
    name: "Initial Consultation",
    price: "Free",
    popular: false,
    features: [
      "Eligibility discussion",
      "High-level pathway review",
      "Next-step checklist",
      "No obligation to continue",
    ],
    button: {
      text: "Book Consultation",
      link: "/contact",
    },
  },
  {
    name: "Application Review",
    price: "Flat Fee",
    popular: true,
    features: [
      "Document checklist review",
      "Form and evidence feedback",
      "Risk and completeness notes",
      "Submission-readiness guidance",
    ],
    button: {
      text: "Request Review",
      link: "/contact",
    },
  },
  {
    name: "Full Representation",
    price: "Custom",
    popular: false,
    features: [
      "File strategy and preparation",
      "Forms and supporting documents",
      "IRCC submission coordination",
      "Ongoing application updates",
    ],
    button: {
      text: "Contact Us",
      link: "/contact",
    },
  },
];
---

<Layout title="Pricing">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Consultation Options</Fragment>
      <Fragment slot="desc">
        Demo service options for common immigration support needs.
      </Fragment>
    </Sectionhead>

    <div
      class="grid md:grid-cols-3 gap-10 mx-auto max-w-(--breakpoint-lg) mt-12">
      {pricing.map((item) => <PricingCard plan={item} />)}
    </div>
  </Container>
</Layout>

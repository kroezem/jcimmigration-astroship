---
import Contactform from "@/components/contactform.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Contact">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Get in Touch</Fragment>
      <Fragment slot="desc">Book a consultation with our team. Half-hour and one-hour appointments are available in person, by phone, or via video call.</Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-16">
      <div>
        <h2 class="font-medium text-2xl text-navy-900">Contact JC Immigration</h2>
        <p class="text-lg leading-relaxed text-navy-600 mt-3">
          Book a consultation with our team. Half-hour and one-hour appointments
          are available in person, by phone, or via video call.
        </p>
        <div class="mt-5">
          <div class="flex items-center mt-2 space-x-2 text-navy-600">
            <Icon class="text-teal-600 w-4 h-4" name="uil:map-marker" />
            <span>Canada-wide consultations</span>
          </div><div class="flex items-center mt-2 space-x-2 text-navy-600">
            <Icon class="text-teal-600 w-4 h-4" name="uil:envelope" /><a
              href="mailto:info@jcimmigration.ca"
              >info@jcimmigration.ca</a
            >
          </div><div class="flex items-center mt-2 space-x-2 text-navy-600">
            <Icon class="text-teal-600 w-4 h-4" name="uil:phone" /><a
              href="tel:+12505550100">(250) 555-0100</a
            >
          </div>
        </div>
      </div>
      <div>
        <Contactform />
      </div>
    </div>
  </Container>
</Layout>

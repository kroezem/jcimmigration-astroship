---
import Link from "./ui/link.astro";
---

<div
  class="bg-navy-800 p-8 md:px-20 md:py-20 mt-20 mx-auto max-w-5xl rounded-lg flex flex-col items-center text-center">
  <h2 class="text-white text-4xl md:text-6xl tracking-tight">
    Ready to Start Your Immigration Journey?
  </h2>
  <p class="text-navy-100 mt-4 text-lg md:text-xl">
    Book a consultation with our team today. Half-hour and one-hour appointments
    available in person, by phone, or via video call.
  </p>
  <div class="flex mt-5">
    <Link href="/contact" style="inverted">Book a Consultation</Link>
  </div>
</div>

---
import Link from "@/components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<main
  class="grid lg:grid-cols-2 place-items-center pt-8 pb-8 md:pt-12 md:pb-24">
  <div class="py-6 md:order-1 hidden md:block">
    <img
      src="https://images.unsplash.com/photo-1517935706615-2717063c2225?w=1200&h=1200&auto=format&fit=crop&q=80"
      alt="Skyline of a Canadian city"
      class="rounded-xl shadow-lg object-cover"
    />
  </div>
  <div>
    <span class="text-teal-600 font-semibold uppercase tracking-wide text-sm">
      Trusted Canadian Immigration Consultants
    </span>
    <h1
      class="text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter text-navy-900 mt-3">
      Your Path to Canada Starts Here
    </h1>
    <p class="text-lg mt-4 text-navy-600 max-w-xl">
      SC Immigration Law has guided families, workers, and students through the
      Canadian immigration process for over 15 years. We know this journey
      personally - and we'll be with you every step of the way.
    </p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <Link
        href="/contact"
        class="flex gap-1 items-center justify-center">
        <Icon class="text-white w-5 h-5" name="bx:bx-calendar" />
        Book a Consultation
      </Link>
      <Link
        size="lg"
        style="outline"
        href="/about"
        class="flex gap-1 items-center justify-center">
        <Icon class="text-navy-700 w-4 h-4" name="bx:bx-info-circle" />
        Learn About Us
      </Link>
    </div>
  </div>
</main>

---
interface Props {
  href: string;
  size?: "md" | "lg";
  block?: boolean;
  style?: "outline" | "primary" | "inverted" | "muted";
  class?: string;
  [x: string]: any;
}

const {
  href,
  block,
  size = "lg",
  style = "primary",
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  lg: "px-5 py-2.5",
  md: "px-4 py-2",
};

const styles = {
  outline: "bg-white border-2 border-navy-700 hover:bg-navy-50 text-navy-700",
  primary: "bg-navy-700 text-white hover:bg-navy-800 border-2 border-transparent",
  inverted: "bg-white text-navy-800 hover:bg-cream-100 border-2 border-transparent",
  muted: "bg-cream-100 hover:bg-navy-50 border-2 border-transparent text-navy-800",
};
---

<a
  href={href}
  {...rest}
  class:list={[
    "rounded-sm text-center transition focus-visible:ring-2 ring-offset-2 ring-gray-200",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}
  ><slot />
</a>
